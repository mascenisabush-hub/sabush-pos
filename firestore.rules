rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sabush POS stores each business's entire operational state (staff list,
    // shifts, stock, sales history, expenses, audit log, etc.) as a single
    // document at /pos/{uid}, where {uid} is the Firebase Auth UID of the
    // business owner who signed in (Google or email/password) — see
    // setupRealtimeSync() / updateState() in index.html.
    //
    // SCOPE NOTE: cashiers do not have their own Firebase Auth accounts. They
    // are identified inside this document via the app's own hashed-PIN system
    // (see pinHash/pinSalt on each staffList entry), not via Firebase Auth.
    // Firestore rules authenticate the Firebase session, not the in-app
    // cashier identity — so these rules can only guarantee that the signed-in
    // business owner is the only Firebase account able to read/write this
    // document. They cannot enforce "a cashier may only close their own
    // shift" or similar at the database layer; that authorization still
    // happens client-side in index.html. Per-cashier database-level
    // enforcement would require giving each cashier their own Firebase Auth
    // identity (e.g. custom tokens minted server-side), which is a larger
    // architecture change, not just a rules change.
    match /pos/{businessId} {
      allow read, write: if request.auth != null && request.auth.uid == businessId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
